# ================== HELPERS: DB ==================
async def table_columns(db: aiosqlite.Connection, table: str) -> set:
    cur = await db.execute(f"PRAGMA table_info({table});")
    rows = await cur.fetchall()
    return {r[1] for r in rows}


async def db_init_safety():
    create_sql = """
    CREATE TABLE IF NOT EXISTS promo_codes (
      code TEXT PRIMARY KEY,
      product TEXT NOT NULL,
      status TEXT NOT NULL DEFAULT 'free'
    );

    CREATE TABLE IF NOT EXISTS activation_links (
      token TEXT PRIMARY KEY,
      product TEXT NOT NULL,
      status TEXT NOT NULL DEFAULT 'active',
      attempts INTEGER NOT NULL DEFAULT 0,
      cdk_code TEXT,
      last_error TEXT,
      created_at TEXT NOT NULL DEFAULT (datetime('now'))
    );
    """
    async with aiosqlite.connect(DB_PATH) as db:
        await db.executescript(create_sql)
        await db.commit()


def only_admin(message_or_call: types.base.TelegramObject) -> bool:
    uid = None
    if isinstance(message_or_call, types.Message):
        uid = message_or_call.from_user.id
    elif isinstance(message_or_call, types.CallbackQuery):
        uid = message_or_call.from_user.id
    return uid == ADMIN_ID


def parse_token(text: str) -> str:
    t = (text or "").strip()
    m = re.search(r"/l/([A-Za-z0-9_\-]+)", t)
    if m:
        return m.group(1)
    return t


async def create_links(product: str, count: int) -> List[str]:
    links = []
    async with aiosqlite.connect(DB_PATH) as db:
        for _ in range(count):
            token = secrets.token_urlsafe(16)
            await db.execute(
                "INSERT INTO activation_links(token, product, status, attempts) VALUES(?, ?, 'active', 0)",
                (token, product),
            )
            links.append(f"{PUBLIC_BASE_URL}/l/{token}")
        await db.commit()
    return links


async def promo_insert_codes(product: str, codes: List[str]) -> Tuple[int, int]:
    inserted = 0
    skipped = 0
    async with aiosqlite.connect(DB_PATH) as db:
        cols = await table_columns(db, "promo_codes")
        if "status" in cols:
            sql = "INSERT OR IGNORE INTO promo_codes(code, product, status) VALUES(?, ?, 'free')"
            params_len = 2
        else:
            sql = "INSERT OR IGNORE INTO promo_codes(code, product) VALUES(?, ?)"
            params_len = 2

        for c in codes:
            c = c.strip()
            if not c:
                continue
            try:
                if params_len == 2:
                    cur = await db.execute(sql, (c, product))
                else:
                    cur = await db.execute(sql, (c, product))
                if cur.rowcount == 1:
                    inserted += 1
                else:
                    skipped += 1
            except Exception:
                skipped += 1

        await db.commit()
    return inserted, skipped


async def promo_count_free(product: str) -> int:
    async with aiosqlite.connect(DB_PATH) as db:
        cols = await table_columns(db, "promo_codes")
        if "status" in cols:
            cur = await db.execute(
                "SELECT COUNT(*) FROM promo_codes WHERE product=? AND status='free'",
                (product,),
            )
        else:
            cur = await db.execute(
                "SELECT COUNT(*) FROM promo_codes WHERE product=?",
                (product,),
            )
        (n,) = await cur.fetchone()
        return int(n)


async def promo_list_free(product: str, offset: int, limit: int) -> Tuple[int, List[str]]:
    async with aiosqlite.connect(DB_PATH) as db:
        cols = await table_columns(db, "promo_codes")
        if "status" in cols:
            cur_total = await db.execute(
                "SELECT COUNT(*) FROM promo_codes WHERE product=? AND status='free'",
                (product,),
            )
            (total,) = await cur_total.fetchone()

            cur = await db.execute(
                "SELECT code FROM promo_codes WHERE product=? AND status='free' ORDER BY rowid LIMIT ? OFFSET ?",
                (product, limit, offset),
            )
        else:
            cur_total = await db.execute(
                "SELECT COUNT(*) FROM promo_codes WHERE product=?",
                (product,),
            )
            (total,) = await cur_total.fetchone()

            cur = await db.execute(
                "SELECT code FROM promo_codes WHERE product=? ORDER BY rowid LIMIT ? OFFSET ?",
                (product, limit, offset),
            )

        rows = await cur.fetchall()
        codes = [r[0] for r in rows]
        return int(total), codes


async def link_info(token: str) -> Optional[dict]:
    async with aiosqlite.connect(DB_PATH) as db:
        cols = await table_columns(db, "activation_links")
        base_cols = ["token", "product", "status"]
        extra = []
        for c in ["attempts", "cdk_code", "last_error", "created_at"]:
            if c in cols:
                extra.append(c)
        sel = base_cols + extra
        cur = await db.execute(
            f"SELECT {', '.join(sel)} FROM activation_links WHERE token=?",
            (token,),
        )
        row = await cur.fetchone()
        if not row:
            return None
        data = dict(zip(sel, row))
        return data

# === ПОИСК ЗАКАЗА ===
async def find_order(order_id: str) -> Optional[dict]:
    async with aiosqlite.connect(DB_PATH) as db:
        try:
            cur = await db.execute(
                "SELECT order_id, product, status, paid_at, activation_token FROM orders WHERE order_id=?",
                (order_id,)
            )
            row = await cur.fetchone()
            if not row: return None
            return {
                "order_id": row[0],
                "product": row[1],
                "status": row[2],
                "paid_at": row[3],
                "token": row[4]
            }
        except Exception:
            return None
