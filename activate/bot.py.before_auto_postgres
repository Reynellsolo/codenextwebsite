def tariffs_inline(prefix: str) -> types.InlineKeyboardMarkup:
    kb = types.InlineKeyboardMarkup()
    kb.add(types.InlineKeyboardButton(PRODUCTS["plus_1m"], callback_data=f"{prefix}:plus_1m"))
    kb.add(types.InlineKeyboardButton(PRODUCTS["go_12m"], callback_data=f"{prefix}:go_12m"))
    kb.add(types.InlineKeyboardButton(PRODUCTS["plus_12m"], callback_data=f"{prefix}:plus_12m"))
    kb.add(types.InlineKeyboardButton("↩️ В меню", callback_data="menu"))
    return kb


def keys_pager_kb(product: str, offset: int, total: int) -> types.InlineKeyboardMarkup:
    kb = types.InlineKeyboardMarkup(row_width=2)
    prev_off = max(0, offset - PAGE_SIZE)
    next_off = offset + PAGE_SIZE

    buttons = []
    if offset > 0:
        buttons.append(types.InlineKeyboardButton("⬅️ Назад", callback_data=f"keys:{product}:{prev_off}"))
    if next_off < total:
        buttons.append(types.InlineKeyboardButton("➡️ Вперёд", callback_data=f"keys:{product}:{next_off}"))

    if buttons:
        kb.row(*buttons)

    kb.add(types.InlineKeyboardButton("🔁 Выбрать другой тариф", callback_data="keys_choose"))
    kb.add(types.InlineKeyboardButton("↩️ В меню", callback_data="menu"))
    return kb


# ================== FSM ==================
