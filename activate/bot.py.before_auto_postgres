# -------- HELPER: show keys page --------
async def show_keys_page(message: types.Message, product: str, offset: int, edit: bool = True):
    total, codes = await promo_list_free(product, offset=offset, limit=PAGE_SIZE)
    start = offset + 1 if total > 0 else 0
    end = min(offset + PAGE_SIZE, total)

    header = (
        f"📋 <b>Лицензии</b> · {PRODUCTS[product]}\n"
        f"Показаны <b>{start}–{end}</b> из <b>{total}</b>\n\n"
    )

    if total == 0:
        body = "Пусто (нет доступных лицензий)."
    else:
        body = "<code>" + "\n".join(codes) + "</code>"

    text = header + body
    kb = keys_pager_kb(product, offset, total)

    if edit:
        await message.edit_text(text, reply_markup=kb)
    else:
        await message.answer(text, reply_markup=kb)


# -------- CALLBACKS: common --------
@dp.callback_query_handler(lambda c: True, state="*")
async def all_callbacks(call: types.CallbackQuery, state: FSMContext):
    if not only_admin(call):
        await call.answer("Нет доступа.", show_alert=True)
        return

    data = call.data or ""

    if data == "menu":
        await state.finish()
        await call.message.edit_text("Главное меню ✅")
        await call.message.answer("Выбери действие:", reply_markup=main_kb())
        await call.answer()
        return

    if data.startswith("mklinks:"):
        product = data.split(":", 1)[1]
        if product not in PRODUCTS:
            await call.answer("Неверный тариф", show_alert=True)
            return
        await state.update_data(product=product)
        await CreateLinks.waiting_count.set()
        await call.message.edit_text(f"Тариф: <b>{PRODUCTS[product]}</b>\n\nНапиши число ссылок (1..500):")
        await call.answer()
        return

    if data.startswith("upcdk:"):
        product = data.split(":", 1)[1]
        if product not in PRODUCTS:
            await call.answer("Неверный тариф", show_alert=True)
            return
        await state.update_data(product=product)
        await UploadCDK.waiting_codes.set()
        await call.message.edit_text(
            f"Тариф: <b>{PRODUCTS[product]}</b>\n\n"
            "Отправь лицензии <b>по одной в строке</b>.\n"
            "Пример:\n"
            "<code>LICENSE-1\nLICENSE-2\nLICENSE-3</code>"
        )
        await call.answer()
        return

    if data.startswith("keyschoose:"):
        product = data.split(":", 1)[1]
        if product not in PRODUCTS:
            await call.answer("Неверный тариф", show_alert=True)
            return
        await show_keys_page(call.message, product=product, offset=0)
        await call.answer()
        return

    if data == "keys_choose":
        await call.message.edit_text("Выбери тариф для просмотра лицензий:")
        await call.message.edit_reply_markup(reply_markup=tariffs_inline("keyschoose"))
        await call.answer()
        return

    if data.startswith("keys:"):
        _, product, off = data.split(":", 2)
        if product not in PRODUCTS:
            await call.answer("Неверный тариф", show_alert=True)
            return
        try:
            offset = int(off)
        except:
            offset = 0
        await show_keys_page(call.message, product=product, offset=offset, edit=True)
        await call.answer()
        return

    await call.answer()


# -------- FSM: CREATE LINKS --------
@dp.message_handler(lambda m: only_admin(m), state=CreateLinks.waiting_count)
async def create_links_count(message: types.Message, state: FSMContext):
    t = (message.text or "").strip()
    if not t.isdigit():
        return await message.answer("Нужно число. Пример: 25")
    count = int(t)
    if count < 1 or count > 500:
        return await message.answer("Диапазон 1..500. Напиши другое число.")

    data = await state.get_data()
    product = data.get("product")
    if product not in PRODUCTS:
        await state.finish()
        return await message.answer("Ошибка состояния. /start", reply_markup=main_kb())

    links = await create_links(product, count)

    await message.answer(f"✅ Сгенерировано: <b>{count}</b>\nТариф: <b>{PRODUCTS[product]}</b>\n\nОтправляю ссылками пачками…")

    chunk = []
    for i, url in enumerate(links, 1):
        chunk.append(url)
        if i % 20 == 0:
            await message.answer("\n".join(chunk))
            chunk = []
    if chunk:
        await message.answer("\n".join(chunk))

    await state.finish()
    await message.answer("Готово ✅", reply_markup=main_kb())


# -------- FSM: UPLOAD CDK --------
@dp.message_handler(lambda m: only_admin(m), state=UploadCDK.waiting_codes)
async def upload_codes(message: types.Message, state: FSMContext):
    data = await state.get_data()
    product = data.get("product")
    if product not in PRODUCTS:
        await state.finish()
        return await message.answer("Ошибка состояния. /start", reply_markup=main_kb())

    raw = message.text or ""
    codes = [line.strip() for line in raw.splitlines() if line.strip()]
    if not codes:
        return await message.answer("Пусто. Отправь ключи по одному в строке.")

    ins, skip = await promo_insert_codes(product, codes)
    left = await promo_count_free(product)

    await message.answer(
        f"✅ Загружено в {PRODUCTS[product]}:\n"
        f"• добавлено: <b>{ins}</b>\n"
        f"• пропущено (дубли/ошибка): <b>{skip}</b>\n"
        f"• остаток free: <b>{left}</b>",
        reply_markup=main_kb()
    )
    await state.finish()


# -------- FSM: CHECK LINK --------
@dp.message_handler(lambda m: only_admin(m), state=CheckLink.waiting_token)
async def check_link(message: types.Message, state: FSMContext):
    token = parse_token(message.text)
    if not token or len(token) < 6:
        return await message.answer("Пришли токен или ссылку вида .../l/{token}")

    info = await link_info(token)
    if not info:
        await state.finish()
        return await message.answer("❌ Не найдено.", reply_markup=main_kb())

    product = info.get("product", "?")
    status = info.get("status", "?")
    attempts = info.get("attempts", 0)
    cdk = info.get("cdk_code") or "—"
    last_error = info.get("last_error") or "—"
    created_at = info.get("created_at") or "—"

    status_text = {
        "active": "⏳ Ожидает",
        "used": "✅ Оформлена",
        "blocked": "🚫 Заблокирована",
    }.get(status, status)

    text = (
        f"🔍 <b>Проверка ссылки</b>\n\n"
        f"Token: <code>{token}</code>\n"
        f"Тариф: <b>{PRODUCTS.get(product, product)}</b>\n"
        f"Статус: <b>{status_text}</b>\n"
        f"Попытки: <b>{attempts}</b> / <b>{MAX_ATTEMPTS}</b>\n"
        f"CDK: <code>{cdk}</code>\n"
        f"Ошибка: <code>{last_error}</code>\n"
        f"Создано: <code>{created_at}</code>\n"
    )

    await state.finish()
    await message.answer(text, reply_markup=main_kb())

# -------- FSM: FIND ORDER --------
@dp.message_handler(lambda m: only_admin(m), state=FindOrder.waiting_id)
async def find_order_handler(message: types.Message, state: FSMContext):
    oid = message.text.strip()
    order = await find_order(oid)
    if not order:
        await state.finish()
        return await message.answer("❌ Заказ не найден.", reply_markup=main_kb())

    token = order.get("token")
    link = f"{PUBLIC_BASE_URL}/l/{token}" if token else "—"
    status = order.get("status")
    
    text = (
        f"📦 <b>Заказ</b>\n"
        f"ID: <code>{oid}</code>\n"
        f"Товар: <b>{PRODUCTS.get(order['product'], order['product'])}</b>\n"
        f"Статус: <b>{status}</b>\n"
        f"Оплачен: {order.get('paid_at') or '—'}\n"
        f"Ссылка: <code>{link}</code>"
    )
    
    await state.finish()
    await message.answer(text, reply_markup=main_kb())


